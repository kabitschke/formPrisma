generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Contato {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String   @unique
  celular     String   @unique
  cpf         String   @unique
  rua         String
  numero      Int
  cidade      String
  bairro      String
  cep         String
  estado      String
  estadoCivil String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
